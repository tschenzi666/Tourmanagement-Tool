# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/tourmanagement?schema=public"

# NextAuth - set NEXTAUTH_URL to your server's public URL
NEXTAUTH_URL="http://YOUR-SERVER-IP:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# AviationStack - Free flight tracking API (500 requests/month)
# Sign up at https://aviationstack.com/ to get your API key
# Leave empty to disable live flight tracking
AVIATIONSTACK_API_KEY=""
